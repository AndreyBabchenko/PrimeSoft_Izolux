        <Dictionary isRef="1" />
        <Name>v_Deliv</Name>
        <NameInSource>baba</NameInSource>
        <Parameters isList="true" count="0" />
        <SqlCommand>set dateformat dmy
select * from v_Deliv 
where (nState &amp; 4 = 4 or nState &amp; 2 = 2)
and Date &gt;= {sDateBeg} and Date &lt;= {sDateEnd} 
{whereDepotSubDivision}</SqlCommand>
      </v_Deliv>
