    <DataSources isList="true" count="1">
      <ReportData Ref="3" type="Stimulsoft.Report.Dictionary.StiOleDbSource" isKey="true">
        <Alias>ReportData</Alias>
        <Columns isList="true" count="19">
          <value>ClientName,System.String</value>
          <value>idTask,System.Int32</value>
          <value>AccountNum,System.String</value>
          <value>PosCount,System.Int32</value>
          <value>Area,System.Double</value>
          <value>nState,System.Int32</value>
          <value>DateComplite,System.DateTime</value>
          <value>DateCompliteGP,System.DateTime</value>
          <value>SawTaskDate,System.DateTime</value>
          <value>idShip,System.Int32</value>
          <value>ShipDate,System.DateTime</value>
          <value>BarCodeState,System.Int32</value>
          <value>BarCodeShip,System.Int32</value>
          <value>BarCodeComplete,System.Int32</value>
          <value>nStateName,System.String</value>
          <value>idBarCode,System.Int32</value>
          <value>TimeScan,System.DateTime</value>
          <value>BarCodeSawed,System.Int32</value>
          <value>BarCodeScaned,System.Int32</value>
        </Columns>
        <CommandTimeout>30</CommandTimeout>
        <Dictionary isRef="1" />
        <Name>ReportData</Name>
        <NameInSource>Соединение</NameInSource>
        <Parameters isList="true" count="0" />
        <SqlCommand>set dateformat dmy
select 
	C.Name    as ClientName,
	T.ID      as idTask,
	T.AccountNum,
	T.PosCount,
	T.Area,
	T.nState,
	TaskState.Name as nStateName,
	T.DateComplite,
	T.DateCompliteGP,
	STM.Data  as SawTaskDate,
	SH.ID     as idShip,
	SH.Date   as ShipDate,
	B.nState as BarCodeState,
	B.ID as idBarCode,
	B.TimeScan,
	case when B.nState &amp; 8 = 8 then 1 else 0 end as BarCodeShip,
    case when B.nState &amp; 4 = 4 then 1 else 0 end as BarCodeSawed,  
    case when B.nState &amp; 128 = 128 then 1 else 0 end as BarCodeComplete, -- Изготовлен
    case when B.TimeScan is not null then 1 else 0 end as BarCodeScaned 
from SawTaskMain STM
inner join GlassDetails GD     on GD.idSawTaskMain = STM.ID
inner join Project       P     on GD.idProject     = P.ID
inner join Task          T     on P.idTask         = T.ID
inner join BarCode       B     on GD.idBarCode     = B.ID
inner join Client        C     on T.idClient       = C.ID
left  join Transport    TR     on TR.idTask        = T.ID
left  join Ship         SH     on TR.idShip        = SH.ID
outer apply 
(
select top 1 *                              -- Выбираем первый подходящий статус из TaskState по битовой маске nState,
    from TaskState                              
    where T.nState &amp; TaskState.ID = TaskState.ID
    order by TaskState.nOrder                   -- учитывая приоритет по nOrder
) as TaskState
where T.DateComplite &gt;= {sDateBeg} and T.DateComplite &lt;= {sDateEnd}
group by
  C.Name,
  T.ID,
  T.AccountNum,
  T.PosCount,
  T.Area,
  T.nState,
  T.DateComplite,
  T.DateCompliteGP,
  STM.Data,
  SH.ID,
  SH.Date,
  B.ID,
  B.nState,
  B.TimeScan,
  TaskState.Name
</SqlCommand>
      </ReportData>
    </DataSources>
